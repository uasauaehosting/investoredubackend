# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/uasa-portal

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# FTP Upload (Hostinger / production static files)
# When set, uploads go to FTP and public URLs are stored in the database.
FTP_HOST=ftp.yourdomain.com
FTP_PORT=21
FTP_USER=your_ftp_username
FTP_PASSWORD=your_ftp_password
FTP_SECURE=false
FTP_REMOTE_PATH=/home/u827794112/domains/ahwuae.com/public_html/investoredu/uploads
FTP_PUBLIC_BASE_URL=https://ahwuae.com/investoredu/uploads

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
